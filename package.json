{
  "name": "zotero-more-columns",
  "type": "module",
  "version": "0.1.0",
  "description": "A lightweight open-source Zotero plugin that adds practical metadata columns to the main item list.",
  "config": {
    "addonName": "Zotero More Columns",
    "addonID": "zotero-more-columns@coekfung.github.io",
    "addonRef": "zoteromorecolumns",
    "addonInstance": "MoreColumns",
    "prefsPrefix": "extensions.zotero.zoteromorecolumns"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coekfung/zotero-more-columns.git"
  },
  "author": "coekfung",
  "bugs": {
    "url": "https://github.com/coekfung/zotero-more-columns/issues"
  },
  "homepage": "https://github.com/coekfung/zotero-more-columns#readme",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "zotero-plugin test --exit-on-finish",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "zotero-plugin-toolkit": "^5.1.2"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@zotero-plugin/eslint-config": "^0.6.9",
    "chai": "^6.2.2",
    "eslint": "^10.1.0",
    "mocha": "^11.7.5",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "zotero-plugin-scaffold": "^0.8.5",
    "zotero-types": "^4.1.2"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
